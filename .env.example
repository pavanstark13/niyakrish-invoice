# Database
DATABASE_URL=postgresql+asyncpg://trader:trader_pass@localhost:5432/trading_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Service URLs (internal docker network)
MARKET_DATA_SERVICE_URL=http://market-data:8001
STRATEGY_ENGINE_URL=http://strategy-engine:8002
RISK_MANAGEMENT_URL=http://risk-management:8003
EXECUTION_ENGINE_URL=http://execution-engine:8004
AI_AGENT_URL=http://ai-agent:8005
MONITORING_URL=http://monitoring:8006

# AI - Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Broker - Alpaca
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Security
SECRET_KEY=your_super_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=INFO

# Postgres (used by docker-compose)
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader_pass
POSTGRES_DB=trading_db

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_pass
